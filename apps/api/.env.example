# Lumen API configuration. Copy to `.env` and adjust. All keys use the API_ prefix.

# Application
API_PROJECT_NAME="Lumen API"
API_ENVIRONMENT=local        # local | staging | production
API_DEBUG=true

# Server
API_HOST=0.0.0.0
API_PORT=8000

# CORS (JSON array)
API_CORS_ORIGINS=["http://localhost:3000"]
